{
    "name": "yiirocks/recaptcha",
    "description": "reCAPTCHA bot protection and online fraud prevention",
    "type": "library",
    "keywords": [
        "yii",
        "yii3",
        "extension",
        "recaptcha",
        "google"
    ],
    "homepage": "https://www.yii.rocks/recaptcha/",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Mr.42",
            "homepage": "https://mr42.me/",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/YiiRocks/recaptcha/issues",
        "source": "https://github.com/YiiRocks/recaptcha/tree/master"
    },
    "require": {
        "php": ">=8.2",
        "yiisoft/validator": "^2.5",
        "yiisoft/di": "^1.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "@stable",
        "phpmd/phpmd": "@stable",
        "phpunit/phpunit": "@stable",
        "squizlabs/php_codesniffer": "@stable",
        "vimeo/psalm": "@stable",
        "yiisoft/config": "^1.6",
        "yiisoft/test-support": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "YiiRocks\\Recaptcha\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YiiRocks\\Recaptcha\\tests\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "scripts": {
        "php-cs-fixer": "@php vendor/bin/php-cs-fixer fix",
        "phpcs": "@php vendor/bin/phpcs",
        "phpmd": "@php vendor/bin/phpmd src/ text tests/data/phpmd_ruleset.xml",
        "phpunit": "@php vendor/bin/phpunit",
        "psalm": "@php vendor/bin/psalm"
    },
    "scripts-descriptions": {
        "php-cs-fixer": "Cleans to code with PHP Coding Standards Fixer.",
        "phpcs": "PHP_CodeSniffer tokenizes PHP, JavaScript and CSS files and detects violations of a defined set of coding standards.",
        "phpmd": "PHP Mess Detector.",
        "phpunit": "PHPUnit - programmer-oriented testing framework.",
        "psalm": "Psalm - static analysis tool for finding errors in PHP applications."
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        },
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php"
        },
        "yiisoft/di": {
            "providers": [
                "YiiRocks\\Recaptcha\\RecaptchaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/config": true
        }
    }
}
